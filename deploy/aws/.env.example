# ─────────────────────────────────────────────────────────────────────────────
# MoneyPenny Dashboard — backend environment template
#
# Copy this file to /opt/moneypenny/backend/.env on the EC2 instance and
# populate every value. The deploy script does the copy if .env is missing;
# you still need to edit the file before the app will function.
#
# NEVER commit the populated .env (it's covered by .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth (dashboard login + JWT) ────────────────────────────────────────────
# Plain password the LoginPage prompts for. Change from any placeholder
# before exposing the server publicly.
DASHBOARD_PASSWORD=
# Random hex string (≥32 chars). Generate with:
#   python3 -c 'import secrets; print(secrets.token_hex(32))'
DASHBOARD_SESSION_SECRET=

# ── Timesheets.com API ──────────────────────────────────────────────────────
TIMESHEET_API_KEY=
TIMESHEET_API_TOKEN=

# ── LLM (chatbot + AI summaries) ────────────────────────────────────────────
GROQ_API_KEY=

# ── Qdrant (vector store for the chatbot) ──────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=

# ── Slack bot (optional — only needed if running slack_bot.py) ─────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SWATHI_SLACK_USER_ID=

# ── Whale API (optional — SOPs tab) ─────────────────────────────────────────
WHALE_API_TOKEN=
WHALE_WORKSPACE_ID=

# ── EOD Google Sheets — per-team overrides ──────────────────────────────────
# Only set these if you need to override the hardcoded sheetId / gid in
# backend/main.py TEAM_LETTER_MAP. Leave blank otherwise.
SHEET_TEAM_A=
GID_TEAM_A=
SHEET_TEAM_B=
GID_TEAM_B=
SHEET_TEAM_C=
GID_TEAM_C=
SHEET_TEAM_D=
GID_TEAM_D=
SHEET_TEAM_E=
GID_TEAM_E=
SHEET_TEAM_F=
GID_TEAM_F=
SHEET_TEAM_G=
GID_TEAM_G=
SHEET_TEAM_H=
GID_TEAM_H=
SHEET_TEAM_I=
GID_TEAM_I=
SHEET_TEAM_J=
GID_TEAM_J=
SHEET_TEAM_K=
GID_TEAM_K=
SHEET_TEAM_L=
GID_TEAM_L=
SHEET_TEAM_M=
GID_TEAM_M=
SHEET_TEAM_N=
GID_TEAM_N=
SHEET_TEAM_T=
GID_TEAM_T=

# Default EOD sheet (used by backend/eod_sheet.py when no team-specific override)
SHEET_ID=

# Admin-Hour weekly review master sheet
WEEKLY_REVIEW_SHEET_ID=

# ABS Tracker sheet
ABS_SHEET_ID=

# ── Build / deploy metadata (optional) ──────────────────────────────────────
# Surfaces the running commit on /api/version. Populate from CI or leave blank.
GIT_COMMIT_SHA=
